APP_NAME="QA Daily Report Bot"
GITHUB_OWNER="example-org"
GITHUB_REPO="example-repo"
GITHUB_TOKEN=""
GITHUB_API_BASE_URL="https://api.github.com"
GITHUB_ISSUE_STATE="open"
GITHUB_LABEL_FILTER=""
MOCK_SCENARIO="normal"
REPORT_TITLE="QA Daily Report"
REPORT_TIMEZONE="Asia/Seoul"
REPORT_OUTPUT_DIR="reports"
SAVE_REPORT_TO_FILE="true"
SAVE_HTML_REPORT_TO_FILE="true"
SAVE_KOREAN_HTML_REPORT_TO_FILE="true"
SAVE_JSON_REPORT_TO_FILE="true"
SAVE_MANIFEST_TO_FILE="true"
SAVE_INDEX_TO_FILE="true"
SAVE_EMAIL_PAYLOAD_TO_FILE="true"
MESSENGER_ENABLED="false"
SLACK_WEBHOOK_URL=""
DISCORD_WEBHOOK_URL=""
EMAIL_ENABLED="false"
EMAIL_RECIPIENTS="qa-team@example.com"
EMAIL_SENDER="qa-report@example.com"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_USE_TLS="true"
